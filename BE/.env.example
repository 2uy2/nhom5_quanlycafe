# .env.example - Copy to .env and configure

# ==============================
# Environment Configuration
# ==============================
NODE_ENV=development

# ==============================
# Server Configuration
# ==============================
PORT=5000

# ==============================
# Database Configuration (MySQL)
# ==============================
# Hostname/IP address of MySQL server
DB_HOST=localhost

# MySQL username
DB_USER=root

# MySQL password (leave empty if no password)
DB_PASSWORD=

# Database name
DB_NAME=coffee_shop_db

# MySQL port (default is 3306)
DB_PORT=3306

# ==============================
# API Configuration
# ==============================
# Backend API URL
API_BASE_URL=http://localhost:5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ==============================
# Notes
# ==============================
# 1. Copy this file: cp .env.example .env
# 2. Update values for your environment
# 3. Never commit .env file with sensitive data
# 4. Keep .env file in .gitignore

# Example configurations for different setups:

# ======= Windows + XAMPP =======
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_PORT=3306

# ======= Windows + MySQL Server =======
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=your_strong_password
# DB_PORT=3306

# ======= macOS + Homebrew =======
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_PORT=3306

# ======= Linux =======
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_PORT=3306

# ======= Production =======
# NODE_ENV=production
# DB_HOST=your-rds-endpoint.amazonaws.com
# DB_USER=admin
# DB_PASSWORD=strong_password
# FRONTEND_URL=https://yourdomain.com
